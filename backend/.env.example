# ── VAPT Report Automation System — Environment Variables Template ─────────────
# Copy this file to backend/.env and fill in real values.
# Never commit backend/.env to source control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="VAPT Report Automation System"
APP_VERSION="2.0.0"
DEBUG=True

# ── Auth — JWT Secret ─────────────────────────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

JWT_EXPIRE_MINUTES=480
